<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>ar0e clone</title>

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #0a0a0a;
  color: #fff;
  font-family: monospace;
  overflow-x: hidden;
}

/* LOADER */
#loader {
  position: fixed;
  width: 100%;
  height: 100%;
  background: black;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

#loader span {
  font-size: 20px;
  color: #aaa;
  animation: blink 1s infinite;
}

@keyframes blink {
  50% { opacity: 0; }
}

/* NAV */
nav {
  position: fixed;
  width: 100%;
  top: 0;
  padding: 15px;
  display: flex;
  justify-content: center;
  gap: 40px;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(5px);
}

nav a {
  color: #888;
  text-decoration: none;
  cursor: pointer;
  transition: 0.3s;
}

nav a:hover {
  color: #fff;
}

/* PAGES */
.page {
  display: none;
  height: 100vh;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  text-align: center;
}

.active {
  display: flex;
}

/* GLITCH TEXT */
.glitch {
  font-size: 60px;
  position: relative;
  color: white;
}

.glitch::before,
.glitch::after {
  content: attr(data-text);
  position: absolute;
  left: 0;
}

.glitch::before {
  color: red;
  animation: glitch1 0.3s infinite;
}

.glitch::after {
  color: blue;
  animation: glitch2 0.3s infinite;
}

@keyframes glitch1 {
  0% { transform: translate(2px, 0); }
  50% { transform: translate(-2px, 0); }
  100% { transform: translate(2px, 0); }
}

@keyframes glitch2 {
  0% { transform: translate(-2px, 0); }
  50% { transform: translate(2px, 0); }
  100% { transform: translate(-2px, 0); }
}

/* LINKS */
.links a {
  display: block;
  width: 250px;
  margin: 10px;
  padding: 12px;
  border: 1px solid #333;
  border-radius: 6px;
  color: white;
  text-decoration: none;
  transition: 0.3s;
}

.links a:hover {
  background: #111;
  transform: scale(1.05);
}
</style>
</head>

<body>

<div id="loader">
  <span>loading...</span>
</div>

<nav>
  <a onclick="showPage('home')">home</a>
  <a onclick="showPage('about')">about</a>
  <a onclick="showPage('links')">links</a>
</nav>

<!-- HOME -->
<div id="home" class="page active">
  <h1 class="glitch" data-text="ar0e">ar0e</h1>
  <p>personal website</p>
</div>

<!-- ABOUT -->
<div id="about" class="page">
  <h1>about me</h1>
  <p>you can write something here</p>
</div>

<!-- LINKS -->
<div id="links" class="page">
  <h1>links</h1>
  <div class="links">
    <a href="#">instagram</a>
    <a href="#">github</a>
    <a href="#">discord</a>
  </div>
</div>

<script>
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

/* loader */
window.onload = () => {
  setTimeout(() => {
    document.getElementById("loader").style.display = "none";
  }, 1000);
};
</script>

</body>
</html>
